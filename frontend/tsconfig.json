{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@pages/*": ["../pages/*"],
      "@assets/*": ["../assets/*"]
    }
  },
  "include": ["src/**/*", "../pages/**/*"]
}
